/target
**/*.rs.bk
Cargo.lock
.idea/
.vscode/
*.swp
*.swo

# ix-voicings: raw GA CLI JSONL dumps can get huge at full corpus;
# keep a small sample corpus + features checked in, ignore the raw stream
# and any voicings artifacts over the checked-in sample size.
/state/voicings/raw/*.jsonl
!/state/voicings/raw/.gitkeep
state/voicings/*-corpus.json
state/voicings/*-features.json

# Adversarial QA: regenerable from CI
state/adversarial/findings.jsonl
state/adversarial/summary.json

# TARS knowledge graph logs — rebuilt from claims ingest
state/graph/
