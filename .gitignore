/target
**/*.rs.bk
Cargo.lock
.idea/
.vscode/
*.swp
*.swo

# ix-voicings: raw GA CLI JSONL dumps can get huge at full corpus;
# keep a small sample corpus + features checked in, ignore the raw stream
# and any voicings artifacts over the checked-in sample size.
/state/voicings/raw/*.jsonl
!/state/voicings/raw/.gitkeep
state/voicings/*-corpus.json
state/voicings/*-features.json
# Exceptions: per-instrument corpus fixtures consumed by the adversarial QA
# workflow (.github/workflows/adversarial-qa.yml) for Layer 1 grounding and
# by the GA Nightly Quality build_ci_index step. Sized as small samples
# (~80KB guitar, ~2MB bass, ~1.3MB ukulele); the rebuild bomb scenario
# (>100MB) needs `git checkout HEAD --` recovery.
!state/voicings/guitar-corpus.json
!state/voicings/bass-corpus.json
!state/voicings/ukulele-corpus.json

# Adversarial QA: regenerable from CI
state/adversarial/findings.jsonl
state/adversarial/summary.json

# TARS knowledge graph logs — rebuilt from claims ingest
state/graph/

# ix-autoresearch: per-run logs are noisy (one JSONL per overnight session);
# only milestones/ is tracked, populated via `ix-autoresearch promote`.
state/autoresearch/runs/*
!state/autoresearch/runs/.gitkeep

# ix-voicings viz: t-SNE / cluster / neighbor JSON outputs are regenerable
# from the OPTIC-K corpus (cargo run -p ix-voicings --example tsne_export).
# Layouts can be 100MB+, so keep them out of the tree.
state/viz/

# Claude Code runtime state (not source): octopus plugin state, agent
# memory caches, PID locks for the /schedule harness.
.claude-octopus/
.claude/agent-memory/
.claude/agent-memory-local/
.claude/scheduled_tasks.lock

# Local IX scratch dir: cargo/clippy round JSONLs, decision briefs,
# remediation snapshots, reports. Regenerable from the source.
.ix/

# Test-only target dir used by harness fixtures.
target-test/

# Python bytecode from ix-optick-sae TopK trainer.
**/__pycache__/
*.pyc

# Session digests — per-session cursor state captured by the /digest skill
# and the PreCompact/Stop hook fallbacks. README is tracked; contents are
# session-specific and may include in-flight model context.
state/digests/*
!state/digests/README.md
